<h2 class="wizard-title">{{ 'wizard.step3.title'|trans({}, 'wizard') }}</h2>
<p class="wizard-subtitle">{{ 'wizard.step3.subtitle'|trans({}, 'wizard') }}</p>

{# Educational explainer — why binding & groups matter for this device type #}
<div class="wizard-explainer">
    {% if stepData.guide.illustration %}
        {% include 'wizard/_illustration_' ~ stepData.guide.illustration ~ '.html.twig' ignore missing %}
    {% endif %}
    <div class="wizard-explainer-body">
        <h3>{{ ('wizard.guide.' ~ stepData.guide.key ~ '.title')|trans({}, 'wizard') }}</h3>
        <p>
            <strong>{{ 'wizard.guide.binding_label'|trans({}, 'wizard') }}</strong>
            {{ ('wizard.guide.' ~ stepData.guide.key ~ '.binding')|trans({}, 'wizard') }}
        </p>
        <p>
            <strong>{{ 'wizard.guide.groups_label'|trans({}, 'wizard') }}</strong>
            {{ ('wizard.guide.' ~ stepData.guide.key ~ '.groups')|trans({}, 'wizard') }}
        </p>
    </div>
</div>

<form method="get" action="{{ path('wizard_index') }}" id="wizard-form-step3">
    <input type="hidden" name="step" value="4">
    <input type="hidden" name="category" value="{{ wizardState.category }}">
    {% for cap in wizardState.capabilities %}
        <input type="hidden" name="capabilities[]" value="{{ cap }}">
    {% endfor %}

    <div class="feature-section">
        <h3>{{ 'wizard.step3.connectivity.title'|trans({}, 'wizard') }}</h3>
        <p>{{ 'wizard.step3.connectivity.description'|trans({}, 'wizard') }}</p>
        <div class="feature-options">
            {% for type, count in stepData.connectivityOptions %}
                {% if count > 0 %}
                    <label class="feature-option">
                        <input type="checkbox" name="connectivity[]" value="{{ type }}"
                               {{ type in wizardState.connectivity ? 'checked' : '' }}>
                        {{ ('wizard.connectivity.' ~ type)|trans({}, 'wizard') }} ({{ count }})
                    </label>
                {% endif %}
            {% endfor %}
        </div>
        <p class="feature-note">{{ 'wizard.step3.connectivity.note'|trans({}, 'wizard') }}</p>
    </div>

    <div class="feature-section">
        <h3>{{ 'wizard.step3.binding.title'|trans({}, 'wizard') }}</h3>
        <p>{{ 'wizard.step3.binding.description'|trans({}, 'wizard') }}</p>
        <div class="feature-options">
            <label class="feature-option">
                <input type="radio" name="binding" value="" {{ wizardState.binding is same as(null) or wizardState.binding == '' ? 'checked' : '' }}>
                {{ 'wizard.step3.binding.any'|trans({}, 'wizard') }}
            </label>
            <label class="feature-option">
                <input type="radio" name="binding" value="1" {{ wizardState.binding == '1' ? 'checked' : '' }}>
                {{ 'wizard.step3.binding.required'|trans({}, 'wizard') }} ({{ stepData.bindingOptions.with_binding|default(0) }})
            </label>
        </div>
    </div>

    <div class="feature-section">
        <h3>{{ 'wizard.step3.rating.title'|trans({}, 'wizard') }}</h3>
        <p>{{ 'wizard.step3.rating.description'|trans({}, 'wizard') }}</p>
        <div class="feature-options">
            <label class="feature-option">
                <input type="radio" name="min_rating" value="" {{ wizardState.min_rating == 0 ? 'checked' : '' }}>
                {{ 'wizard.step3.rating.any'|trans({}, 'wizard') }}
            </label>
            {% for rating in [3, 4, 5] %}
                <label class="feature-option">
                    <input type="radio" name="min_rating" value="{{ rating }}"
                           {{ wizardState.min_rating == rating ? 'checked' : '' }}>
                    {{ rating }}+ &#9733;
                </label>
            {% endfor %}
        </div>
    </div>

    <div class="wizard-nav">
        <a href="{{ path('wizard_index', {
            step: 2,
            category: wizardState.category,
            capabilities: wizardState.capabilities
        }) }}" class="wizard-btn wizard-btn-secondary">
            &larr; {{ 'wizard.back'|trans({}, 'wizard') }}
        </a>
        <button type="submit" class="wizard-btn wizard-btn-primary">
            {{ 'wizard.continue'|trans({}, 'wizard') }} &rarr;
        </button>
    </div>
</form>
