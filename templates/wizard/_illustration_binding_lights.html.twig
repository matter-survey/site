{# Inline diagram: a switch bound directly to bulbs (binding), and bulbs acting
   as one (groups). Decorative — hidden from assistive tech, the prose explains it. #}
<svg class="wizard-illustration" viewBox="0 0 240 150" role="img"
     aria-label="{{ 'wizard.guide.lights.illustration_alt'|trans({}, 'wizard') }}" focusable="false">
    {# --- Binding: switch -> bulbs --- #}
    <g fill="none" stroke="var(--primary)" stroke-width="2">
        {# switch #}
        <rect x="8" y="34" width="34" height="46" rx="5" fill="var(--blue-100)"/>
        <line x1="25" y1="46" x2="25" y2="68"/>
        <circle cx="25" cy="46" r="3" fill="var(--primary)" stroke="none"/>
        {# wires to each bulb #}
        <path d="M42 50 C 80 40, 110 32, 150 32"/>
        <path d="M42 57 C 80 57, 110 57, 150 57"/>
        <path d="M42 64 C 80 74, 110 82, 150 82"/>
    </g>
    {# bulbs #}
    <g>
        {% for y in [32, 57, 82] %}
            <circle cx="162" cy="{{ y }}" r="11" fill="var(--blue-100)" stroke="var(--primary)" stroke-width="2"/>
            <path d="M157 {{ y + 13 }} h10" stroke="var(--gray-400)" stroke-width="2"/>
        {% endfor %}
    </g>
    {# --- Groups: brace around the bulbs --- #}
    <g fill="none" stroke="var(--green-700)" stroke-width="2">
        <path d="M182 22 q 8 0 8 8 v 18 q 0 8 8 8 q -8 0 -8 8 v 18 q 0 8 -8 8"/>
    </g>
    <text x="206" y="61" fill="var(--green-700)" font-size="11" font-weight="600">
        {{ 'wizard.guide.groups_label_short'|trans({}, 'wizard') }}
    </text>
    {# label under switch #}
    <text x="25" y="96" fill="var(--gray-500)" font-size="10" text-anchor="middle">
        {{ 'wizard.guide.lights.switch_label'|trans({}, 'wizard') }}
    </text>
</svg>
