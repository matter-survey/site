{% extends 'base.html.twig' %}

{% block structured_data %}{{ include('stats/_dataset_jsonld.html.twig') }}{% endblock %}

{% block title %}Matter Survey - Coordination Features{% endblock %}

{% block header_subtitle %}<p>Devices that work together: direct control (binding), bulk control (groups), and saved states (scenes)</p>{% endblock %}

{% block extra_styles %}
    .dashboard-nav {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .dashboard-nav a {
        padding: 0.5rem 1rem;
        background: white;
        border: 1px solid var(--gray-200);
        border-radius: 0.375rem;
        text-decoration: none;
        color: var(--gray-700);
        font-size: 0.875rem;
    }

    .dashboard-nav a:hover {
        background: var(--gray-100);
    }

    .dashboard-nav a.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    .stats-row {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .stat-card {
        background: white;
        padding: 1rem 1.5rem;
        border-radius: 0.5rem;
        border: 1px solid var(--gray-200);
    }

    .stat-card .value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary);
    }

    .stat-card .label {
        font-size: 0.75rem;
        color: var(--gray-500);
    }

    .info-box {
        background: var(--blue-100);
        border-radius: 0.5rem;
        padding: 1rem 1.25rem;
        margin-bottom: 2rem;
        font-size: 0.875rem;
        color: var(--blue-700);
    }

    .info-box strong {
        display: block;
        margin-bottom: 0.25rem;
    }

    .section {
        background: white;
        border-radius: 0.5rem;
        border: 1px solid var(--gray-200);
        margin-bottom: 2rem;
        scroll-margin-top: 1rem;
    }

    .section-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--gray-200);
    }

    .section-header h2 {
        font-size: 1rem;
        font-weight: 600;
        margin: 0;
    }

    .section-header p {
        font-size: 0.75rem;
        color: var(--gray-500);
        margin: 0.25rem 0 0;
    }

    .category-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem;
        padding: 1.25rem;
    }

    .category-card {
        padding: 1rem;
        background: var(--gray-50);
        border-radius: 0.5rem;
    }

    .category-card .name {
        font-weight: 600;
        font-size: 0.875rem;
        margin-bottom: 0.75rem;
    }

    .coord-metric {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.75rem;
        color: var(--gray-700);
        margin-bottom: 0.5rem;
    }

    .coord-metric .pct {
        font-weight: 600;
    }

    .progress-bar {
        width: 100%;
        height: 6px;
        background: var(--gray-200);
        border-radius: 3px;
        overflow: hidden;
        margin-top: 0.25rem;
    }

    .progress-bar .fill {
        height: 100%;
        border-radius: 3px;
    }

    .fill-binding { background: var(--green-700); }
    .fill-groups { background: var(--blue-700); }
    .fill-scenes { background: #9333ea; }

    .device-table {
        width: 100%;
        border-collapse: collapse;
    }

    .device-table th,
    .device-table td {
        padding: 0.75rem 1.25rem;
        text-align: left;
        border-bottom: 1px solid var(--gray-100);
    }

    .device-table th {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--gray-500);
        text-transform: uppercase;
    }

    .device-table tr:last-child td {
        border-bottom: none;
    }

    .device-table tr:hover td {
        background: var(--gray-50);
    }

    .device-table a {
        color: var(--gray-900);
        text-decoration: none;
        font-weight: 500;
    }

    .device-table a:hover {
        color: var(--primary);
    }

    .badge {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .badge-endpoints {
        background: var(--gray-100);
        color: var(--gray-700);
    }
{% endblock %}

{% block body %}
    {{ include('stats/_nav.html.twig', { active: 'stats_coordination' }) }}

    {{ include('stats/_header.html.twig', {
        title: 'Coordination & Interoperability',
        subtitle: 'How Matter devices work together — binding, groups, and scenes',
        color: 'indigo'
    }) }}

    <div class="info-box">
        <strong>Three ways Matter devices coordinate</strong>
        <strong style="font-weight:600;">Binding</strong> lets a device (often a switch or sensor) control others directly, without a hub.
        <strong style="font-weight:600;">Groups</strong> let a device be addressed in bulk, so one command reaches many devices at once.
        <strong style="font-weight:600;">Scenes</strong> let a device save and recall preset states (e.g. &ldquo;movie night&rdquo;).
    </div>

    <div class="stats-row">
        {% for key, feature in features %}
            <div class="stat-card">
                <div class="value">{{ feature.count|number_format }}</div>
                <div class="label">{{ feature.label }}</div>
            </div>
        {% endfor %}
        <div class="stat-card">
            <div class="value">{{ stats.total_devices|number_format }}</div>
            <div class="label">Total Devices</div>
        </div>
    </div>

    <div class="section">
        <div class="section-header">
            <h2>Coordination Support by Category</h2>
            <p>Percentage of devices in each category supporting each coordination feature</p>
        </div>
        <div class="category-grid">
            {% for category, data in byCategory %}
                <div class="category-card">
                    <div class="name">{{ category }} <span style="font-weight:400; color: var(--gray-400);">({{ data.total }})</span></div>
                    {% for key, feature in features %}
                        <div class="coord-metric">
                            <span>{{ feature.label }}</span>
                            <span class="pct">{{ attribute(data, key ~ '_pct') }}%</span>
                        </div>
                        <div class="progress-bar">
                            <div class="fill fill-{{ key }}" style="width: {{ attribute(data, key ~ '_pct') }}%"></div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p style="color: var(--gray-500); grid-column: 1 / -1; text-align: center;">No category data available yet.</p>
            {% endfor %}
        </div>
    </div>

    {% for key, feature in features %}
        <div class="section" id="{{ key }}">
            <div class="section-header">
                <h2>{{ feature.label }}</h2>
                <p>{{ feature.role }}</p>
            </div>
            <table class="device-table">
                <thead>
                    <tr>
                        <th>Device</th>
                        <th>Vendor</th>
                        <th>Submissions</th>
                        <th>Endpoints</th>
                    </tr>
                </thead>
                <tbody>
                    {% for device in feature.devices %}
                        <tr>
                            <td>
                                <a href="{{ path('device_show', {slug: device.slug}) }}">
                                    {{ device.product_name ?? 'Unknown Product' }}
                                </a>
                            </td>
                            <td>
                                {% if device.vendor_slug %}
                                    <a href="{{ path('vendor_show', {slug: device.vendor_slug}) }}" style="font-weight: normal;">
                                        {{ device.vendor_name ?? 'Unknown' }}
                                    </a>
                                {% else %}
                                    {{ device.vendor_name ?? 'Unknown' }}
                                {% endif %}
                            </td>
                            <td>{{ device.submission_count }}</td>
                            <td>
                                <span class="badge badge-endpoints">{{ device.endpoint_count }}</span>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" style="text-align: center; color: var(--gray-500);">
                                No devices with {{ feature.label|lower }} found yet.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endfor %}
{% endblock %}
