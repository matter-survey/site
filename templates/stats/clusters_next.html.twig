{% extends 'base.html.twig' %}

{% block title %}Coming in the next Matter release - Matter Survey{% endblock %}

{% block og_title %}Upcoming Matter cluster changes ({{ releasedVersion }} → next){% endblock %}
{% block og_description %}{{ newClusters|length }} new clusters and {{ revisionBumps|length }} ClusterRevision bumps queued for the next Matter release, derived from connectedhomeip master.{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .page-header {
        padding: 1rem 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        background: white;
        border-radius: 0.5rem;
        border: 1px solid var(--gray-200);
    }

    .page-header h1 {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 0 0 0.5rem;
    }

    .page-header p {
        margin: 0;
        color: var(--gray-600);
        font-size: 0.9375rem;
    }

    .page-header .baseline {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.75rem;
        padding: 0.375rem 0.75rem;
        background: var(--gray-50);
        border: 1px solid var(--gray-200);
        border-radius: 0.375rem;
        font-size: 0.8125rem;
        color: var(--gray-700);
    }

    .page-header .baseline code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8125rem;
        background: white;
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
    }

    .section {
        background: white;
        border-radius: 0.5rem;
        border: 1px solid var(--gray-200);
        margin-bottom: 1.5rem;
    }

    .section-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
    }

    .section-header h2 {
        font-size: 1rem;
        font-weight: 600;
        margin: 0;
    }

    .section-header .count {
        color: var(--gray-500);
        font-size: 0.875rem;
    }

    .new-cluster-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.75rem;
        padding: 1rem 1.25rem;
    }

    .new-cluster-card {
        display: flex;
        flex-direction: column;
        gap: 0.375rem;
        padding: 0.875rem;
        background: var(--gray-50);
        border-radius: 0.375rem;
        text-decoration: none;
        color: inherit;
        transition: background-color 0.15s;
    }

    .new-cluster-card:hover {
        background: var(--gray-100);
    }

    .new-cluster-card .name {
        font-weight: 500;
        font-size: 0.9375rem;
    }

    .new-cluster-card .hex {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.75rem;
        color: var(--gray-500);
    }

    .new-cluster-card .description {
        font-size: 0.8125rem;
        color: var(--gray-600);
        line-height: 1.4;
    }

    .badge-provisional {
        display: inline-block;
        background: #fef3c7;
        color: #92400e;
        font-size: 0.6875rem;
        padding: 0.125rem 0.375rem;
        border-radius: 9999px;
        font-weight: 500;
    }

    .rev-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

    .rev-table thead {
        background: var(--gray-50);
        border-bottom: 1px solid var(--gray-200);
    }

    .rev-table th {
        padding: 0.625rem 1rem;
        text-align: left;
        font-weight: 500;
        color: var(--gray-700);
    }

    .rev-table td {
        padding: 0.625rem 1rem;
        border-bottom: 1px solid var(--gray-100);
    }

    .rev-table .hex,
    .rev-table .rev {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8125rem;
        color: var(--gray-600);
    }

    .rev-arrow {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8125rem;
    }

    .rev-arrow .from {
        color: var(--gray-500);
    }

    .rev-arrow .to {
        color: #166534;
        font-weight: 600;
    }

    .rev-table a {
        color: inherit;
        text-decoration: none;
    }

    .rev-table a:hover {
        text-decoration: underline;
    }

    .empty {
        padding: 1.5rem 1.25rem;
        color: var(--gray-500);
        font-size: 0.875rem;
        text-align: center;
    }
</style>
{% endblock %}

{% block body %}
<div class="container">
    <p class="breadcrumbs">
        <a href="{{ path('stats_clusters') }}">Clusters</a> &raquo; Coming in next Matter release
    </p>

    <div class="page-header">
        <h1>Coming in the next Matter release</h1>
        <p>
            Cluster changes queued in
            <a href="https://github.com/project-chip/connectedhomeip">connectedhomeip master</a>
            relative to the most recent released Matter spec.
            These are draft until the next CSA tag — names, IDs, and revision counters can still change.
        </p>
        <div class="baseline">
            Baseline: Matter <code>{{ releasedVersion }}</code> &nbsp;→&nbsp; Reference: <code>master</code>
        </div>
    </div>

    <div class="section">
        <div class="section-header">
            <h2>New clusters</h2>
            <span class="count">{{ newClusters|length }} cluster{{ newClusters|length != 1 ? 's' : '' }}</span>
        </div>
        {% if newClusters|length > 0 %}
        <div class="new-cluster-grid">
            {% for c in newClusters %}
                <a href="{{ path('stats_cluster_version_show', {hexId: '0x' ~ '%04X'|format(c.clusterId), matterVersion: 'master'}) }}" class="new-cluster-card">
                    <div class="name">
                        {{ c.name }}
                        {% if c.apiMaturity %}
                            <span class="badge-provisional">{{ c.apiMaturity|capitalize }}</span>
                        {% endif %}
                    </div>
                    <div class="hex">0x{{ '%04X'|format(c.clusterId) }}</div>
                    {% if c.description %}
                        <div class="description">{{ c.description }}</div>
                    {% endif %}
                </a>
            {% endfor %}
        </div>
        {% else %}
        <p class="empty">No new clusters queued.</p>
        {% endif %}
    </div>

    <div class="section">
        <div class="section-header">
            <h2>ClusterRevision bumps</h2>
            <span class="count">{{ revisionBumps|length }} cluster{{ revisionBumps|length != 1 ? 's' : '' }}</span>
        </div>
        {% if revisionBumps|length > 0 %}
        <table class="rev-table">
            <thead>
                <tr>
                    <th style="width: 100px;">Code</th>
                    <th>Cluster</th>
                    <th style="width: 200px;">Revision</th>
                </tr>
            </thead>
            <tbody>
                {% for bump in revisionBumps %}
                <tr>
                    <td class="hex">{{ bump.hexId }}</td>
                    <td><a href="{{ path('stats_cluster_show', {hexId: bump.hexId}) }}">{{ bump.name }}</a></td>
                    <td>
                        <span class="rev-arrow">
                            <span class="from">rev {{ bump.fromRevision }}</span>
                            <span>→</span>
                            <span class="to">rev {{ bump.toRevision }}</span>
                        </span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p class="empty">No revision bumps queued.</p>
        {% endif %}
    </div>
</div>
{% endblock %}
