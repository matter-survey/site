# Symfony Environment Configuration
# Local overrides go in .env.local (not committed)

APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-me-in-production

# Default URI for generating URLs in CLI commands
DEFAULT_URI=http://localhost:8000

# Canonical origin used for <link rel="canonical"> and hreflang.
# Must be the single host you want Google to index under (no trailing slash).
CANONICAL_BASE_URL=https://matter-survey.org

# Deployment settings (override in .env.local)
# SFTP_USER=
# SFTP_HOST=
# SFTP_PATH=

###> doctrine/doctrine-bundle ###
DATABASE_URL="sqlite:///%kernel.project_dir%/data/matter-survey.db"
###< doctrine/doctrine-bundle ###

###> open-telemetry/sdk ###
# Master switch: telemetry is OFF by default. Flip in .env.local to enable.
OTEL_SDK_DISABLED=true

# Service identity (overridden at boot from APP_ENV for deployment.environment.name)
OTEL_SERVICE_NAME=matter-survey
OTEL_SERVICE_VERSION=dev

# Pinned to no-extension-required transport. Real endpoint goes in .env.local
# (e.g. OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.example/, plus
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer xyz for managed backends).
OTEL_EXPORTER_OTLP_PROTOCOL=http/json

# Defaults: traces only when enabled; metrics/logs flip on in Phase 3.
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# Buffer spans before export so requests don't pay for HTTP latency.
OTEL_PHP_TRACES_PROCESSOR=batch

# Sample everything by default; lower the arg later if volume grows.
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
###< open-telemetry/sdk ###

###> symfony/framework-bundle ###
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###
